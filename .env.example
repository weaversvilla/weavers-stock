# Weavers Villa — Stock Intelligence
# Add these to Vercel Dashboard → Settings → Environment Variables
# NEVER commit this file with real values

BASELINKER_API_TOKEN=your_baselinker_api_token_here
BL_INVENTORY_ID=1257
BL_WAREHOUSE_ID=9001890

# NO series IDs needed — documents are fetched by type directly:
# Sales  → doc_type "order"
# Returns → doc_type "return"
# Internal adjustments (stocktake, transfer etc.) are automatically excluded

